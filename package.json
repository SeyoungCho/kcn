{
  "name": "kcn",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "next-themes": "npm:@teispace/next-themes@0.3.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
