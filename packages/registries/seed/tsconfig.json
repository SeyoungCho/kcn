{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/react-library",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/components/**/*.tsx", "src/components/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
